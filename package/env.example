# ==========================================
# Control Plane Environment Variables
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
APP_TIMEZONE="UTC"
APP_HTTP_PORT="8080"
APP_LOG_LEVEL="info"
APP_PUBLIC_URL="http://localhost:8080"
APP_ENABLE_RATE_LIMIT="false"
APP_TRUSTED_PROXIES=""
APP_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# ------------------------------------------
# Security
# ------------------------------------------
CORE_SECRET_MASTER_KEY=""
SECURITY_ADMIN_API_TOKEN_TTL="15m"
SECURITY_ADMIN_API_TOKEN_ROTATE_BEFORE="5m"
SECURITY_SECRET_ROTATE_INTERVAL="24h"
SECURITY_SECRET_PREVIOUS_OVERLAP="24h"
SECURITY_ADMIN_BOOTSTRAP_TOKEN_PATH="/run/aurora-iam/bootstrap-admin-token"
SECURITY_ADMIN_BOOTSTRAP_TOKEN_FILE_TTL="5m"

# ------------------------------------------
# Rate limit
# ------------------------------------------
RATE_LIMIT_LOGIN_CAPACITY="10"
RATE_LIMIT_LOGIN_REFILL="10"
RATE_LIMIT_LOGIN_PERIOD="1m"
RATE_LIMIT_REFRESH_CAPACITY="20"
RATE_LIMIT_REFRESH_REFILL="20"
RATE_LIMIT_REFRESH_PERIOD="1m"
RATE_LIMIT_FORGOT_CAPACITY="5"
RATE_LIMIT_FORGOT_REFILL="5"
RATE_LIMIT_FORGOT_PERIOD="5m"
RATE_LIMIT_RESET_CAPACITY="10"
RATE_LIMIT_RESET_REFILL="10"
RATE_LIMIT_RESET_PERIOD="5m"
RATE_LIMIT_MFA_CAPACITY="15"
RATE_LIMIT_MFA_REFILL="15"
RATE_LIMIT_MFA_PERIOD="1m"
RATE_LIMIT_ADMIN_CAPACITY="10"
RATE_LIMIT_ADMIN_REFILL="10"
RATE_LIMIT_ADMIN_PERIOD="1m"

# ------------------------------------------
# PostgreSQL Database
# ------------------------------------------
PSQL_HOST="localhost"
PSQL_PORT="5432"
PSQL_USER="postgres"
PSQL_PASSWORD=""
PSQL_DBNAME="aurora"
PSQL_SSLMODE="disable"

# PostgreSQL TLS configuration
PSQL_TLS_ENABLED="false"
PSQL_TLS_CA=""
PSQL_TLS_CERT=""
PSQL_TLS_KEY=""

# PostgreSQL Connection Pool
PSQL_MAX_CONNS="20"
PSQL_MIN_CONNS="5"
PSQL_MAX_CONN_LIFE="30m"
PSQL_MAX_CONN_IDLE="5m"
PSQL_PING_TIMEOUT="5s"
PSQL_MAX_RETRIES="5"
PSQL_RETRY_INTERVAL="3s"

# ------------------------------------------
# Redis
# ------------------------------------------
REDIS_ADDR="localhost:6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# Redis TLS configuration
REDIS_TLS_ENABLED="false"
REDIS_TLS_CA=""
REDIS_TLS_CERT=""
REDIS_TLS_KEY=""

# Redis Pool & Timeouts
REDIS_DIAL_TIMEOUT="5s"
REDIS_READ_TIMEOUT="3s"
REDIS_WRITE_TIMEOUT="3s"
REDIS_POOL_SIZE="20"
REDIS_MIN_IDLE_CONNS="5"
REDIS_PING_TIMEOUT="5s"
REDIS_MAX_RETRIES="5"
REDIS_RETRY_INTERVAL="3s"

# ------------------------------------------
# gRPC
# ------------------------------------------
GRPC_SERVER_PORT="9090"
GRPC_SERVER_TLS_ENABLED="false"
GRPC_SERVER_TLS_CERT=""
GRPC_SERVER_TLS_KEY=""
GRPC_DATAPLANE_CLIENT_CA=""
GRPC_DATAPLANE_CLIENT_CA_KEY=""
GRPC_DATAPLANE_ENROLL_TOKEN=""
GRPC_DATAPLANE_CLIENT_CERT_TTL="720h"
GRPC_DATAPLANE_HEARTBEAT_INTERVAL="30s"
GRPC_DATAPLANE_STALE_TIMEOUT="2m"
GRPC_CLIENT_TLS_ENABLED="false"
GRPC_CLIENT_TLS_CA=""
GRPC_CLIENT_TLS_CERT=""
GRPC_CLIENT_TLS_KEY=""
